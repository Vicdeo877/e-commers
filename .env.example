# Copy to `.env.local` and fill in values. Never commit `.env` or `.env.local`.

# Database (SQLite dev: file path relative to prisma/). Production: use Postgres/MySQL URL from your host.
DATABASE_URL="file:./dev.db"

# Public site URL (no trailing slash) — must match the URL users open in the browser (OAuth, uploads, image URLs).
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: server-side API base when SSR calls a different origin (rare)
# NEXT_INTERNAL_API_URL=http://localhost:3000

# Razorpay — https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# Google Sign-In — https://console.cloud.google.com/apis/credentials
# Add every redirect URI you use, e.g. http://localhost:3000/api/auth/google/callback and your production URL.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
# NEXT_PUBLIC_GOOGLE_SIGNIN=0

# Optional: Abstract email validation — https://www.abstractapi.com/api/email-validation-api
# EMAIL_VERIFICATION_API_KEY=

# Admin: allow clearing .next from Admin UI in production (default: dev only)
# ALLOW_ADMIN_CACHE_CLEAR=true
